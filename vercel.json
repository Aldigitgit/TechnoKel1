{
    "outputDirectory": "public/build",
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "@vercel/php@0.7.3"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)\\.(css|js|map|ico|jpg|jpeg|png|gif|svg|webp|woff|woff2|ttf|eot)$",
            "dest": "/public/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}